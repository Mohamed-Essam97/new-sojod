rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Users: any signed-in user can read (needed for profile), own write
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
      match /memberships/{groupId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Wird: only owner can read/write
    match /wirds/{userId}/daily/{date} {
      allow read, write: if isOwner(userId);
    }
    
    // Groups: signed-in users can read/write (simplified for now)
    match /groups/{groupId} {
      allow read, write: if isSignedIn();
      match /members/{memberId} {
        allow read, write: if isSignedIn();
      }
      match /invites/{inviteCode} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
